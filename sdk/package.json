{
  "name": "@swiftremit/sdk",
  "version": "1.0.0",
  "description": "TypeScript client SDK for the SwiftRemit Soroban smart contract",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "docs": "typedoc src/index.ts --out docs --plugin typedoc-plugin-markdown",
    "docs:serve": "http-server docs -p 8080 -o"
  },
  "keywords": [
    "stellar",
    "soroban",
    "swiftremit",
    "remittance",
    "usdc"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=13.0.0"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^13.0.0",
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "typedoc": "^0.25.1",
    "typedoc-plugin-markdown": "^4.0.0",
    "vitest": "^4.1.8"
  }
}
